{
  "name": [
    "scriptevent"
  ],
  "description": "通过ID和消息来触发脚本事件",
  "syntax": [
    "/scriptevent <messageId: string> <message: message>"
  ],
  "node": {
    "<messageId: string>": {
      "type": "STRING",
      "brief": "消息ID",
      "description": "触发脚本事件的消息ID",
      "canContainSpace": true,
      "ignoreLater": false
    },
    "<message: message>": {
      "type": "STRING",
      "brief": "文本",
      "description": "要显示的文本",
      "canContainSpace": true,
      "ignoreLater": true
    }
  }
}