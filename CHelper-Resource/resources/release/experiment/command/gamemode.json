{
  "name": [
    "gamemode"
  ],
  "description": "设置玩家的游戏模式",
  "syntax": [
    "/gamemode <gameMode: GameMode> [player: target]",
    "/gamemode <gameMode: int> [player: target]"
  ],
  "node": {
    "<gameMode: GameMode>|<gameMode: int>": {
      "type": "NORMAL_ID",
      "brief": "游戏模式",
      "description": "玩家的新游戏模式",
      "ignoreError": true,
      "key": "gameMode"
    },
    "[player: target]": {
      "type": "TARGET_SELECTOR",
      "description": "目标实体",
      "isOnlyOne": false,
      "isMustPlayer": true,
      "isMustNPC": false,
      "isWildcard": false
    }
  }
}