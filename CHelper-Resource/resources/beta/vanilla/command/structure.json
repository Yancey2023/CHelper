{
  "name": [
    "structure"
  ],
  "description": "保存或加载结构",
  "syntax": [
    "/structure delete <name: string>",
    "/structure load <name: string> <to: x y z> [rotation: Rotation] [mirror: Mirror] [animationMode: StructureAnimationMode] [animationSeconds: float] [includeEntities: Boolean] [includeBlocks: Boolean] [waterlogged: Boolean] [integrity: float] [seed: string]",
    "/structure load <name: string> <to: x y z> [rotation: Rotation] [mirror: Mirror] [includeEntities: Boolean] [includeBlocks: Boolean] [waterlogged: Boolean] [integrity: float] [seed: string]",
    "/structure save <name: string> <from: x y z> <to: x y z> [includeEntities: Boolean] [saveMode: StructureSaveMode] [includeBlocks: Boolean]",
    "/structure save <name: string> <from: x y z> <to: x y z> [saveMode: StructureSaveMode]"
  ],
  "node": {
    "delete": {
      "type": "TEXT",
      "description": "删除某个储存的结构文件",
      "data": {
        "name": "delete",
        "description": "删除某个储存的结构文件"
      }
    },
    "<name: string>": {
      "type": "STRING",
      "brief": "结构名",
      "description": "加载的结构名称或文件名称",
      "canContainSpace": true,
      "ignoreLater": false
    },
    "load": {
      "type": "TEXT",
      "description": "加载一个结构",
      "data": {
        "name": "load",
        "description": "加载一个结构"
      }
    },
    "<to: x y z>": {
      "type": "POSITION",
      "brief": "目标区域坐标",
      "description": "目标区域的西北方向较低（即在各轴上坐标值最小）的点的坐标"
    },
    "[rotation: Rotation]": {
      "type": "NORMAL_ID",
      "brief": "旋转角度",
      "description": "结构旋转的角度",
      "ignoreError": false,
      "contents": [
        {
          "name": "0_degrees",
          "description": "不旋转"
        },
        {
          "name": "90_degrees",
          "description": "按顺时针旋转90°"
        },
        {
          "name": "180_degrees",
          "description": "按顺时针旋转180°"
        },
        {
          "name": "270_degrees",
          "description": "按顺时针旋转270°"
        }
      ]
    },
    "[mirror: Mirror]": {
      "type": "NORMAL_ID",
      "brief": "镜像模式",
      "description": "结构的镜像模式",
      "ignoreError": false,
      "contents": [
        {
          "name": "none",
          "description": "无"
        },
        {
          "name": "x",
          "description": "沿x轴翻转"
        },
        {
          "name": "z",
          "description": "沿z轴翻转"
        },
        {
          "name": "xz",
          "description": "沿x及z轴翻转"
        }
      ]
    },
    "[animationMode: StructureAnimationMode]": {
      "type": "NORMAL_ID",
      "brief": "生成动画",
      "description": "生成结构使用的动画",
      "ignoreError": false,
      "contents": [
        {
          "name": "block_by_block",
          "description": "一个方块一个方块地放置"
        },
        {
          "name": "layer_by_layer",
          "description": "一层一层地放置"
        }
      ]
    },
    "[animationSeconds: float]": {
      "type": "FLOAT",
      "description": "动画的时长"
    },
    "[includeEntities: Boolean]": {
      "type": "BOOLEAN",
      "brief": "是否包含实体",
      "description": "结构中是否包含实体",
      "descriptionTrue": "包含实体",
      "descriptionFalse": "不包含实体"
    },
    "[includeBlocks: Boolean]": {
      "type": "BOOLEAN",
      "brief": "是否包含方块",
      "description": "结构中是否包含方块",
      "descriptionTrue": "包含方块",
      "descriptionFalse": "不包含方块"
    },
    "[waterlogged: Boolean]": {
      "type": "BOOLEAN",
      "brief": "是否含水",
      "description": "方块是否含水",
      "descriptionTrue": "含水",
      "descriptionFalse": "不含水"
    },
    "[integrity: float]": {
      "type": "FLOAT",
      "brief": "结构完整度",
      "description": "结构的完整度"
    },
    "[seed: string]": {
      "type": "STRING",
      "brief": "随机种子",
      "description": "用于随机删除结构中的方块的种子",
      "canContainSpace": false,
      "ignoreLater": false
    },
    "save": {
      "type": "TEXT",
      "description": "保存一个结构",
      "data": {
        "name": "save",
        "description": "保存一个结构"
      }
    },
    "<from: x y z>": {
      "type": "POSITION",
      "brief": "坐标1",
      "description": "保存结构时的对角坐标1"
    },
    "[saveMode: StructureSaveMode]": {
      "type": "NORMAL_ID",
      "brief": "保存模式",
      "description": "结构保存模式",
      "ignoreError": false,
      "contents": [
        {
          "name": "memory",
          "description": "保存在内存中"
        },
        {
          "name": "disk",
          "description": "保存至磁盘"
        }
      ]
    }
  }
}