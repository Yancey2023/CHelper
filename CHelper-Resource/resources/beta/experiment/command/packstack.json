{
  "name": [
    "packstack"
  ],
  "description": "显示资源包和行为包数据。",
  "syntax": [
    "/packstack <stackType: stackType> [verbose: verbose] [exclude-vanilla: exclude-vanilla]"
  ],
  "node": {
    "<stackType: stackType>": {
      "type": "NORMAL_ID",
      "brief": "包的类型",
      "description": "包的类型",
      "ignoreError": false,
      "contents": [
        {
          "name": "client",
          "description": "资源包"
        },
        {
          "name": "server",
          "description": "行为包和脚本模块"
        }
      ]
    },
    "[verbose: verbose]": {
      "type": "TEXT",
      "description": "显示未启用的包和包的详细信息",
      "data": {
        "name": "verbose",
        "description": "显示未启用的包和包的详细信息"
      }
    },
    "[exclude-vanilla: exclude-vanilla]": {
      "type": "TEXT",
      "description": "排除原版包",
      "data": {
        "name": "exclude-vanilla",
        "description": "排除原版包"
      }
    }
  }
}