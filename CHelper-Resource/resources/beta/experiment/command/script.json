{
  "name": [
    "script"
  ],
  "description": "调试GameTest框架选项",
  "syntax": [
    "/script debugger close",
    "/script debugger connect [host: string] [port: int]",
    "/script debugger listen <port: int>",
    "/script diagnostics startcapture",
    "/script diagnostics stopcapture",
    "/script profiler start",
    "/script profiler stop"
  ],
  "node": {
    "debugger": {
      "type": "TEXT",
      "description": "调试GameTest框架选项",
      "data": {
        "name": "debugger",
        "description": "调试器"
      }
    },
    "close": {
      "type": "TEXT",
      "description": "关闭调试器",
      "data": {
        "name": "close",
        "description": "关闭调试器"
      }
    },
    "connect": {
      "type": "TEXT",
      "description": "连接调试器至指定主机",
      "data": {
        "name": "connect",
        "description": "将调试器的指定端口连接至指定主机"
      }
    },
    "[host: string]": {
      "type": "STRING",
      "description": "主机名称",
      "canContainSpace": true,
      "ignoreLater": false
    },
    "[port: int]|<port: int>": {
      "type": "INTEGER",
      "brief": "调试器端口",
      "description": "调试器端口，可用端口范围为1024-65535",
      "min": 1024,
      "max": 65535
    },
    "listen": {
      "type": "TEXT",
      "description": "监听调试器端口",
      "data": {
        "name": "listen",
        "description": "监听调试器的指定端口"
      }
    },
    "diagnostics": {
      "type": "TEXT",
      "description": "开始或停止捕获诊断",
      "data": {
        "name": "diagnostics",
        "description": "开始或停止捕获诊断"
      }
    },
    "startcapture": {
      "type": "TEXT",
      "description": "开始捕获诊断",
      "data": {
        "name": "startcapture",
        "description": "开始捕获诊断"
      }
    },
    "stopcapture": {
      "type": "TEXT",
      "description": "停止捕获诊断",
      "data": {
        "name": "stopcapture",
        "description": "停止捕获诊断"
      }
    },
    "profiler": {
      "type": "TEXT",
      "description": "分析器",
      "data": {
        "name": "profiler",
        "description": "分析器"
      }
    },
    "start": {
      "type": "TEXT",
      "description": "启用分析器",
      "data": {
        "name": "start",
        "description": "启用跟踪脚本性能的分析器"
      }
    },
    "stop": {
      "type": "TEXT",
      "description": "禁用分析器",
      "data": {
        "name": "stop",
        "description": "禁用分析器"
      }
    }
  }
}