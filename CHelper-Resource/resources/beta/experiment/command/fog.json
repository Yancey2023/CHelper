{
  "name": [
    "fog"
  ],
  "description": "更改玩家的迷雾效果",
  "syntax": [
    "/fog <victim: target> <mode: delete> <userProvidedId: string>",
    "/fog <victim: target> push <fogId: string> <userProvidedId: string>"
  ],
  "node": {
    "<victim: target>": {
      "type": "TARGET_SELECTOR",
      "description": "修改玩家迷雾效果的目标",
      "isOnlyOne": false,
      "isMustPlayer": true,
      "isMustNPC": false,
      "isWildcard": false
    },
    "<mode: delete>": {
      "type": "NORMAL_ID",
      "description": "删除模式",
      "ignoreError": false,
      "contents": [
        {
          "name": "pop",
          "description": "只移除第一个"
        },
        {
          "name": "remove",
          "description": "移除全部"
        }
      ]
    },
    "<userProvidedId: string>": {
      "type": "STRING",
      "brief": "迷雾名称",
      "description": "迷雾设置的名称",
      "canContainSpace": true,
      "ignoreLater": false
    },
    "push": {
      "type": "TEXT",
      "description": "更改玩家的迷雾效果",
      "data": {
        "name": "push",
        "description": "更改玩家的迷雾效果"
      }
    },
    "<fogId: string>": {
      "type": "NORMAL_ID",
      "brief": "迷雾ID",
      "description": "修改的迷雾ID",
      "ignoreError": true,
      "key": "fog"
    }
  }
}