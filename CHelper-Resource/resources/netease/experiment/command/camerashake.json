{
  "name": [
    "camerashake"
  ],
  "description": "对玩家视野施以一定强度和时间的摇晃效果",
  "syntax": [
    "/camerashake add <player: target> [intensity: float] [seconds: float] [shakeType: CameraShakeType]",
    "/camerashake stop [player: target]"
  ],
  "node": {
    "add": {
      "type": "TEXT",
      "description": "给玩家添加视野摇晃效果",
      "data": {
        "name": "add",
        "description": "给玩家添加视野摇晃效果"
      }
    },
    "<player: target>|[player: target]": {
      "type": "TARGET_SELECTOR",
      "description": "要施以视野摇晃效果的玩家(默认为命令执行者)",
      "isOnlyOne": false,
      "isMustPlayer": true,
      "isMustNPC": false,
      "isWildcard": false
    },
    "[intensity: float]": {
      "type": "FLOAT",
      "brief": "摇晃强度",
      "description": "视野摇晃的强度",
      "min": 0,
      "max": 4
    },
    "[seconds: float]": {
      "type": "FLOAT",
      "brief": "摇晃时长",
      "description": "视野摇晃的时长"
    },
    "[shakeType: CameraShakeType]": {
      "type": "NORMAL_ID",
      "brief": "摇晃种类",
      "description": "视野摇晃方向的种类",
      "ignoreError": false,
      "contents": [
        {
          "name": "positional",
          "description": "坐标摇晃"
        },
        {
          "name": "rotational",
          "description": "角度摇晃"
        }
      ]
    },
    "stop": {
      "type": "TEXT",
      "description": "停止视野摇晃",
      "data": {
        "name": "stop",
        "description": "停止视野摇晃"
      }
    }
  }
}