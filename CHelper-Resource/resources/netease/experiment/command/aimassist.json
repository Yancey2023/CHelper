{
  "name": [
    "aimassist"
  ],
  "description": "设定与清除瞄准辅助",
  "syntax": [
    "/aimassist <player: target> clear",
    "/aimassist <player: target> set [xAngle: float] [yAngle: float] [maxDistance: float] [targetMode: string] [presetId: string]",
    "/aimassist <player: target> set [xAngle: float] [yAngle: float] [maxDistance: float] [targetMode: string]",
    "/aimassist <player: target> set [xAngle: float] [yAngle: float] [maxDistance: float]",
    "/aimassist <player: target> set [xAngle: float] [yAngle: float]",
    "/aimassist <player: target> set [xAngle: float]",
    "/aimassist <player: target> set"
  ],
  "node": {
    "<player: target>": {
      "type": "TARGET_SELECTOR",
      "description": "被修改瞄准辅助的玩家",
      "isOnlyOne": false,
      "isMustPlayer": true,
      "isMustNPC": false,
      "isWildcard": false
    },
    "clear": {
      "type": "TEXT",
      "description": "清除瞄准辅助",
      "data": {
        "name": "clear",
        "description": "清除瞄准辅助"
      }
    },
    "set": {
      "type": "TEXT",
      "description": "设定瞄准辅助",
      "data": {
        "name": "set",
        "description": "设定瞄准辅助"
      }
    },
    "[xAngle: float]": {
      "type": "FLOAT",
      "brief": "X轴角度",
      "description": "指定X轴角度",
      "min": 10,
      "max": 90
    },
    "[yAngle: float]": {
      "type": "FLOAT",
      "brief": "Y轴角度",
      "description": "指定Y轴角度",
      "min": 10,
      "max": 90
    },
    "[maxDistance: float]": {
      "type": "FLOAT",
      "brief": "最大距离",
      "description": "指定最大距离",
      "min": 1,
      "max": 16
    },
    "[targetMode: string]": {
      "type": "NORMAL_ID",
      "brief": "瞄准模式",
      "description": "指定瞄准模式, 默认为距离",
      "ignoreError": true,
      "contents": [
        {
          "name": "distance",
          "description": "指定瞄准模式为距离"
        },
        {
          "name": "angle",
          "description": "指定瞄准模式为角度"
        }
      ]
    },
    "[presetId: string]": {
      "type": "STRING",
      "brief": "预设ID",
      "description": "指定预设ID",
      "canContainSpace": true,
      "ignoreLater": false
    }
  }
}